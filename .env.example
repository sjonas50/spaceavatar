# Commander Sky — environment template. Copy to .env (never commit .env).
# All keys are server-side only; nothing here ever reaches the browser.

# LiveKit Cloud (Ship plan or above — Build plan has 10-20s cold starts)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Model providers
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
LEMONSLICE_API_KEY=

# Avatar rendering path: lemonslice | frontend | none  (Phase 2 bake-off decides)
AVATAR_MODE=lemonslice
# LemonSlice character: either a saved agent ID or a single character image URL
LEMONSLICE_AGENT_ID=
LEMONSLICE_IMAGE_URL=

# Model overrides (defaults in agent/src/commander_sky/config.py)
#LLM_MODEL=claude-sonnet-4-6
#STT_MODEL=flux-general-en
#TTS_MODEL=sonic-3.5
#TTS_VOICE=

# Session policy
MAX_SESSION_MINUTES=15
MAX_SESSION_COST_USD=5.0

# Kid-tuned turn taking
ENDPOINTING_DELAY_S=0.9
BARGE_IN_MIN_WORDS=3
